# iOS / App Store Connect credentials
IOS_BUNDLE_ID=your-bundle-id-here
IOS_TEAM_ID=your-team-id-here
IOS_API_KEY_ID=your-api-key-id-here
IOS_API_ISSUER_ID=your-issuer-id-here
IOS_API_KEY_PATH=/path/to/AuthKey.p8

# Snap Store credentials
SNAP_STORE_EMAIL=your-snap-store-email-here
SNAP_STORE_PASSWORD=your-snap-store-password-here